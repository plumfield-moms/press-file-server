{
  "name": "plumfield-press-server",
  "version": "1.0.0",
  "description": "Local Proof Review System",
  "scripts": {
    "server": "cd server && node index.js",
    "client": "cd client && pnpm run dev",
    "dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
    "install-all": "pnpm install && cd server && pnpm install && cd ../client && pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
